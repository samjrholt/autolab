# Environment / secrets
.env
.env.local
.env.*.local
!.env.example

# ---- Pixi ----
# The pixi.lock file IS committed (it is a lockfile, like package-lock.json).
# Only the resolved environment cache is ignored.
.pixi/

# ---- Node / frontend ----
node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
*.tsbuildinfo

# ---- IDE / editor ----
.idea/
.vscode/
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- Tool caches ----
.direnv/
.tool-versions
.autolab-runs/

# ---- autolab runtime artefacts ----
# The ledger, cached tool outputs, generated PDF reports, and any
# Lab state rehydrated at runtime. Test fixtures under tests/ are
# checked in explicitly; only these runtime paths are ignored.
.autolab-work/
/data/
/ledger/
/cache/
/reports/
/test-results/
/var/demo_lab/
/var/*.log
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db
*.db-journal

# Brainstorm scratch (visual companion)
.superpowers/

# Playwright run output
frontend/test-results/
frontend/playwright-report/
