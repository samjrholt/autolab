# Copy this file to `.env` and fill in your values. `.env` is gitignored.
#
# autolab boots without an API key (Claude integrations fall back to a
# deterministic offline stub), so you can explore the Console + ledger +
# Optuna planner without one. The ANTHROPIC_API_KEY is required to use
# Claude as a Planner / PolicyProvider / Campaign Designer.

# Required for Claude-driven campaigns and the free-text Campaign Designer.
# Get one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=sk-ant-...

# Optional — override the model. Default is claude-opus-4-7 (1M context).
# AUTOLAB_CLAUDE_MODEL=claude-opus-4-7

# Optional — force the offline stub even when a key is set. Useful for tests.
# AUTOLAB_CLAUDE_OFFLINE=1

# Optional — choose where the Lab persists state. Default is ./.autolab-runs/default.
# AUTOLAB_ROOT=./.autolab-runs/default

# Optional — apply a named bootstrap on server boot.
# Values: none, demo_quadratic, sensor_shape_opt, mammos, superellipse,
# all, shell_command, wsl_ssh_demo, or `module:fn` for a custom bootstrap.
# AUTOLAB_BOOTSTRAP=none
